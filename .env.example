PORT=4000
# Optional. Multiple keys can be comma-separated. Keys can have their own limits below.
# API_KEYS=replace-with-a-long-random-secret
# Optional per-key overrides. Format: api-key=requests-per-window
# API_KEY_LIMITS=your-second-api-key=120
# Requests permitted per API key within each window.
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SECONDS=60
# Requests permitted without an API key. Default: 60 requests every five minutes per IP address.
ANONYMOUS_RATE_LIMIT_MAX=60
ANONYMOUS_RATE_LIMIT_WINDOW_SECONDS=300
# Set to the number of trusted reverse-proxy hops when using Nginx, Caddy, or Traefik.
TRUST_PROXY_HOPS=0
# Used by the scraper when local tab-export JSON files are available.
MMC_TAB_DIR=/app/data
# Optional overrides for persistent runtime paths.
API_DATA_DIR=/app/data
API_LOG_DIR=/app/logs
# Optional public URL used by /v1/generator/:name.
API_BASE_URL=https://api.example.com

PORT=4000
# Required. Multiple keys can be comma-separated.
API_KEYS=replace-with-a-long-random-secret
# Requests permitted per API key within each window.
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SECONDS=60
# Used by the scraper when local tab-export JSON files are available.
MMC_TAB_DIR=/app/data
# Optional overrides for persistent runtime paths.
API_DATA_DIR=/app/data
API_LOG_DIR=/app/logs
# Optional public URL used by /v1/generator/:name.
API_BASE_URL=https://api.example.com
